{
	"name": "GCode Royal Dark",
	"type": "dark",
	"colors": {
		"editor.background": "#111318",
		"editor.foreground": "#e8e8e8",
		"editorLineNumber.foreground": "#4B5563",
		"editorLineNumber.activeForeground": "#AAB2C0",
		"editorCursor.foreground": "#F8F8F2",
		"editor.selectionBackground": "#2D3A4A",
		"editor.inactiveSelectionBackground": "#263241",
		"editorIndentGuide.background1": "#252B34",
		"editorIndentGuide.activeBackground1": "#3B4252"
	},
	"tokenColors": [
		{
			"name": "Normal comments",
			"scope": "comment.line.gcode",
			"settings": {
				"foreground": "#67825e"
			}
		},
		{
			"name": "Title comments",
			"scope": "comment.title.gcode",
			"settings": {
				"foreground": "#f2ad0c",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Meta comments",
			"scope": "comment.meta.gcode",
			"settings": {
				"foreground": "#95b8bf"
			}
		},

		{
			"name": "Macro variables",
			"scope": "variable.parameter.gcode",
			"settings": {
				"foreground": "#ffffff"
			}
		},

		{
			"name": "Program number",
			"scope": "entity.name.program.gcode",
			"settings": {
				"foreground": "#FFD866",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Block number",
