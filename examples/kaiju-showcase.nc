O0901 (KAIJU.NC SHOWCASE - EDITOR FEATURE SAMPLE ONLY)
(/ THIS FILE IS FOR EXTENSION TESTING AND DOCUMENTATION)
(/ DO NOT RUN THIS FILE ON A MACHINE)

(---KAIJU ALIAS SETUP EXAMPLES---)
(/ ALIAS STYLE 1: COMMENT-ONLY REFERENCES)
(#100 = PART OD)
(#101 = FINISH Z)
(#102 = ROUGHING DEPTH)
(#103 = FINISH ALLOWANCE)
(#104 = ROUGHING FEED)
(#105 = FINISH FEED)
(#106 = SAFE Z)
(#107 = RAPID CLEARANCE)

(---ALIAS STYLE 2: INITIAL ASSIGNMENTS WITH COMMENTS---)
#108 = 3 (LOOP COUNT)
#109 = 0 (CURRENT PASS)
#110 = #100 (CURRENT OD)
#120 = 1.500 (ARC I CENTER)
#121 = -0.750 (ARC K CENTER)
#130 = 1800 (SPINDLE RPM)
#131 = 2400 (FINISH RPM)
#500 = 101 (ROUGH TOOL)
#501 = 197 (FINISH TOOL BASE)
#180 = 123.456 (UNUSED SETUP MACRO - ORPHAN KILLER DEMO)

(---COMMENT-ONLY REFERENCES STILL NEED NORMAL ASSIGNMENTS SOMEWHERE---)
#100 = 50.000
#101 = -38.000
#102 = 2.000
#103 = 0.300
#104 = 0.250
#105 = 0.120
#106 = 5.000
#107 = 2.000

(/ TRY KAIJU ALIAS NOW: RIGHT CLICK AND CHOOSE KAIJU ALIAS)
(/ OR USE CTRL+ALT+A ON WINDOWS/LINUX, CMD+ALT+A ON MAC)
(/ IT WILL TOGGLE #100 STYLE VARIABLES INTO #part_od STYLE ALIASES)

N100 (--ROUGH TURNING--)
T#500 (change to roughing tool)
G97 S#130 M03
G00 X[#100 + #107] Z#106
G01 Z0.000 F#104

WHILE[#109 LT #108] DO1
	#109 = #109 + 1
	#110 = #100 - [#102 * #109]
	G00 X[#110 + #103] Z[#107]
	G01 Z#101 F#104
	G00 X[#100 + #107]
END1

N200 (--FINISH TURNING--)
T[#501 + 5]
G97 S#131 M03
G00 X[#100 + #107] Z#106
G01 X[#100 + #103] Z0.000 F#105
G02 X[#100 - 4.000] Z-4.000 I#120 K#121
G01 Z#101
G00 X[#100 + #107] Z#106
M05

N300 (--FIX THIS AREA WITH KAIJU RECONSTRUCTOR--)
(/ RIGHT CLICK IN THIS FILE AND CHOOSE KAIJU RECONSTRUCTOR)
(/ OR USE CTRL+ALT+R ON WINDOWS/LINUX, CMD+ALT+R ON MAC)
(/ EXPECTED CLEANUPS:)
(/ 0 -> 0.000)
(/ g1 -> G01)
(/ x0 -> X0.000)
(/ z-20 -> Z-20.000)
(/ f.18 -> F0.180)
(/ G43 Z4.H2 -> G43 Z4.000 H2)
(/ T9 -> T09)
(/ T606 -> T0606)
g1x0z-20f.18 (spacing, casing, and decimal formatting demo)
G43 Z4.H2 (height offset spacing demo)
T9 (tool padding demo)
T606 (tool normalization demo)

N400 (--DIAGNOSTIC AND ORPHAN KILLER DEMO - INTENTIONAL ISSUES BELOW--)
(/ TRY KAIJU ORPHAN KILLER: RIGHT CLICK AND CHOOSE KAIJU ORPHAN KILLER)
(/ OR USE CTRL+ALT+O ON WINDOWS/LINUX, CMD+ALT+O ON MAC)
G01 X40 Z-10 F2 (missing decimal warnings)
G01 X[#100 + 1] Z[#101 - 2] (missing decimal warnings inside brackets)
#190 = 9.000 (DEFINED BUT UNUSED MACRO)
G01 X#100 Z#199 F#105 (UNDEFINED #199 FOR ORPHAN KILLER)
(COMMENTED MACRO #777 AND <DISPLAY #778> ARE IGNORED BY ORPHAN KILLER)

M30
%
