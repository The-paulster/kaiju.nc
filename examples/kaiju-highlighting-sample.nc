%
O1200 <KAIJU.NC HIGHLIGHTING SAMPLE>
(/ SCREENSHOT SAMPLE ONLY - DO NOT RUN ON A MACHINE)

(--- MAIN TITLE / OPERATION COMMENT ---)
(- OPERATION 10 - ROUGH AND FINISH TURN)
(/ META: SHOWS COMMENTS, CODES, AXES, MACROS, AND LOGIC)
(STANDARD COMMENT WITH [BRACKETED NOTE])

#100 = 2.000 (START OD)
#101 = -1.250 (FINISH Z)
#102 = 0.125 (STEP DOWN)
#103 = 0.012 (FINISH FEED)
#110 = 0 (PASS COUNT)
#120 = [#100 - #102] (CURRENT OD)

N100 (SETUP AND RAPID POSITION)
T0101
G97 S1800 M03
G00 X[#100 + 0.100] Z0.100

N200 (CUTTING MOTION AND ADDRESS WORDS)
G01 X#120 Z#101 F0.008
G02 X1.500 Z-0.750 I-0.250 K0.000 R0.125
G03 X1.750 Z-1.000 I0.125 K-0.125
G01 U-0.020 W-0.050 A15.00 B30.00 C45.00 L2 P100

N300 (RETRACT, TOOL CHANGE, AND FINISH CUT)
G00 X3.000 Z0.500
M09
M05
T0202
G97 S2200 M03
M08
G00 X[#120 + 0.050] Z0.050

N400 (MATHS AND CONDITIONAL LOGIC)
IF[#120 GT 1.000] THEN #120 = #120 - #102
WHILE[#110 LT 3] DO1
  #110 = #110 + 1
  #130 = ROUND[SIN[30] * ABS[#102]]
  G01 X[#120 - [#102 * #110]] Z-0.400 F#103
  G02 X[#120 - 0.250] Z-0.650 I-0.125 K0.000 R0.125
  IF[#130 NE 0] GOTO 400
END1

N400 (FINISH PASS)
G96 S450
G01 X[#120 + #102] Z#101 F#103
M05
M30
%


