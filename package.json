{
  "name": "kaiju-nc",
  "displayName": "KAIJU.NC",
  "description": "VSCode extension for working with .nc files. Provides syntax highlighting, warnings, automatic formatting, and basic diagnostic tools.",
  "version": "0.1.1",
  "icon": "media/kaiju-nc_128x128icon.png",
  "publisher": "PaulCGilesLawson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-paulster/kaiju.nc.git"
  },
  "bugs": {
    "url": "https://github.com/The-paulster/kaiju.nc/issues"
  },
  "homepage": "https://github.com/The-paulster/kaiju.nc#readme",
  "keywords": [
    "gcode",
    "g-code",
    "nc",
    "cnc",
    "cnc-programming",
    "fanuc",
    "machining",
    "macro",
    "macro-variables",
    "cnc-macro",
    "syntax-highlighting",
    "formatter",
    "g-code-formatter",
    "lathe",
    "turning",
    "mill",
    "milling",
    "mill-turn",
    "tooling",
    "kakou",
    "加工",
    "マシニング"
  ],
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gcode",
        "aliases": ["GCode", "gcode"],
        "extensions": [
          ".nc",
          ".cnc",
          ".tap",
          ".gcode",
          ".gco",
          ".gc",
          ".ngc",
          ".ncc",
          ".eia",
          ".iso",
          ".min",
          ".mpf",
          ".spf",
          ".dnc",
          ".sub"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gcode",
        "scopeName": "source.gcode",
        "path": "./syntaxes/gcode.tmLanguage.json"
      }
    ],
    


    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "name": "Normal comments",
                "scope": "comment.line.gcode",
                "settings": {
                    "foreground": "#67825e"
                }
            },
            {
                "name": "Title comments",
                "scope": "comment.title.gcode",
                "settings": {
                    "foreground": "#f2ad0c",
                    "fontStyle": "bold"
                }
            },
            {
                "name": "Meta comments",
                "scope": "comment.meta.gcode",
                "settings": {
                    "foreground": "#95b8bf"
                }
            },
            {
                "name": "Macro variables",
                "scope": "variable.parameter.gcode",
                "settings": {
                    "foreground": "#ffffff"
                }
            },
            {
                "name": "Program number",
                "scope": "entity.name.program.gcode",
                "settings": {
                    "foreground": "#FFD866",
                    "fontStyle": "bold"
                }
            },
            {
                "name": "Block number",
                "scope": "entity.block.number.gcode",
                "settings": {
                    "foreground": "#c4c4c4"
                }
            },
            {
                "name": "Rapid motion G0",
                "scope": "keyword.motion.rapid.gcode",
                "settings": {
                    "foreground": "#ff8800"
                }
            },
            {
                "name": "Cutting motion G1/G2/G3",
                "scope": "keyword.motion.cut.gcode",
                "settings": {
                    "foreground": "#ffd500"
                }
            },
            {
                "name": "Other G-codes",
                "scope": "keyword.control.gcode",
                "settings": {
                    "foreground": "#29c718"
                }
            },
            {
                "name": "M-codes",
                "scope": "keyword.control.mcode.gcode",
                "settings": {
                    "foreground": "#9CDCFE"
                }
            },
            {
                "name": "X axis",
                "scope": "support.axis.x.gcode",
                "settings": {
                    "foreground": "#D65D5D"
                }
            },
            {
                "name": "U axis / X incremental",
                "scope": "support.axis.u.gcode",
                "settings": {
                    "foreground": "#FF8A8A"
                }
            },
            {
                "name": "Y axis",
                "scope": "support.axis.y.gcode",
                "settings": {
                    "foreground": "#6A9955"
                }
            },
            {
                "name": "V axis / Y incremental",
                "scope": "support.axis.v.gcode",
                "settings": {
                    "foreground": "#9CDC7C"
                }
            },
            {
                "name": "Z axis",
                "scope": "support.axis.z.gcode",
                "settings": {
                    "foreground": "#4A90E2"
                }
            },
            {
                "name": "W axis / Z incremental",
                "scope": "support.axis.w.gcode",
                "settings": {
                    "foreground": "#8CC8FF"
                }
            },
            {
                "name": "Radius R",
                "scope": "support.radius.r.gcode",
                "settings": {
                    "foreground": "#D19A66"
                }
            },
            {
                "name": "Feed F",
                "scope": "support.feed.f.gcode",
                "settings": {
                    "foreground": "#ffd84d"
                }
            },
            {
                "name": "L code",
                "scope": "support.code.l.gcode",
                "settings": {
                    "foreground": "#B5CEA8"
                }
            },
            {
                "name": "P code",
                "scope": "support.code.p.gcode",
                "settings": {
                    "foreground": "#D7BA7D"
                }
            },
            {
                "name": "Q code",
                "scope": "support.code.q.gcode",
                "settings": {
                    "foreground": "#CE9178"
                }
            },
            {
                "name": "S code",
                "scope": "support.code.s.gcode",
                "settings": {
                    "foreground": "#ff0037"
                }
            },
            {
                "name": "T code",
                "scope": "support.code.t.gcode",
                "settings": {
                    "foreground": "#88ff00",
                    "fontStyle": "bold"
                }
            },
            {
                "name": "H code",
                "scope": "support.code.h.gcode",
                "settings": {
                    "foreground": "#A6E66A",
                    "fontStyle": "bold"
                }
            },
            {
                "name": "Math symbol operators",
                "scope": "keyword.operator.math.symbol.gcode",
                "settings": {
                    "foreground": "#ABB2BF"
                }
            },
            {
                "name": "Math word operators",
                "scope": "keyword.operator.math.word.gcode",
                "settings": {
                    "foreground": "#eb17e4"
                }
            },
            {
                "name": "Logic Word Operators",
                "scope": "keyword.control.logic.gcode",
                "settings": {
                    "foreground": "#eb17e4"
                }
            },
            {
                "name": "Double comment",
                "scope": "comment.double.gcode",
                "settings": {
                    "foreground": "#94709c"
                }
            },
            {
                "name": "A rotary axis",
                "scope": "support.axis.a.gcode",
                "settings": {
                    "foreground": "#8E6BB8"
                }
            },
            {
                "name": "B rotary axis",
                "scope": "support.axis.b.gcode",
                "settings": {
                    "foreground": "#A878D6"
                }
            },
            {
                "name": "C rotary axis",
                "scope": "support.axis.c.gcode",
                "settings": {
                    "foreground": "#C678DD"
                }
            },
            {
                "name": "I arc / X arc component",
                "scope": "support.arc.i.gcode",
                "settings": {
                    "foreground": "#B94F5A"
                }
            },
            {
                "name": "J arc / Y arc component",
                "scope": "support.arc.j.gcode",
                "settings": {
                    "foreground": "#5F8F4E"
                }
            },
            {
                "name": "K arc / Z arc component",
                "scope": "support.arc.k.gcode",
                "settings": {
                    "foreground": "#4B82C2"
                }
            },
            {
                "name": "Main title comment",
                "scope": "comment.maintitle.gcode",
                "settings": {
                    "foreground": "#D0FF00",
                    "fontStyle": "bold"
                }
            }
        ]
      },
      "[gcode]": {
        "editor.colorDecorators": false,
        "editor.defaultColorDecorators": "never"
      },
      "files.associations": {
        "*.nc": "gcode",
        "*.cnc": "gcode",
        "*.tap": "gcode",
        "*.gcode": "gcode",
        "*.gco": "gcode",
        "*.gc": "gcode",
        "*.ngc": "gcode",
        "*.ncc": "gcode",
        "*.eia": "gcode",
        "*.iso": "gcode",
        "*.min": "gcode",
        "*.mpf": "gcode",
        "*.spf": "gcode",
        "*.dnc": "gcode",
        "*.sub": "gcode"
      }
    },
    "configuration": [
      {
        "title": "KAIJU.NC: Syntax",
        "properties": {
          "kaijuNC.syntax.toolDecorations.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Show KAIJU.NC tool-range gutter markers beside G-code programs."
          }
        }
      },
      {
        "title": "KAIJU.NC: Reconstructor",
        "properties": {
          "kaijuNC.format.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable KAIJU.NC document formatting for G-code files."
          },
          "kaijuNC.format.decimalPlaces": {
            "type": "integer",
            "default": 3,
            "minimum": 0,
            "maximum": 9,
            "description": "Default number of decimal places used by KAIJU Reconstructor."
          },
          "kaijuNC.format.addMissingDecimal": {
            "type": "boolean",
            "default": true,
            "description": "Add a decimal point to configured address values when one is missing."
          },
          "kaijuNC.format.decimalAddressLetters": {
            "type": "string",
            "default": "XYZUVWABCIJKRF",
            "description": "Address letters whose numeric values should be formatted with decimal places."
          },
          "kaijuNC.format.autoSemicolon": {
            "type": "boolean",
            "default": false,
            "description": "Add semicolons after code and before comments during formatting."
          },
          "kaijuNC.format.normalizeToolCodes": {
            "type": "boolean",
            "default": true,
            "description": "Normalize T codes to four digits, such as T1 to T0101 and T606 to T0606."
          }
        }
      },
      {
        "title": "KAIJU.NC: Alias",
        "properties": {
          "kaijuNC.alias.caseSensitive": {
            "type": "boolean",
            "default": false,
            "description": "Match KAIJU Alias macro names case-sensitively when toggling aliases. Disabled by default so #PART_OD can still toggle back to #100."
          }
        }
      },
      {
        "title": "KAIJU.NC: Orphan Killer",
        "properties": {
          "kaijuNC.orphanKiller.compactPanelWidth": {
            "type": "number",
            "default": 0.3,
            "minimum": 0.15,
            "maximum": 0.5,
            "description": "Target width fraction for the KAIJU Orphan Killer side editor group when VS Code has a simple two-column layout."
          },
          "kaijuNC.orphanKiller.ignoredMacros": {
            "type": "string",
            "default": "1001-",
            "description": "Comma-separated macro numbers or ranges ignored by KAIJU Orphan Killer, such as 100, 123, 3000-4000, or 1001- for all macros above #1000. Clear this setting to inspect every numeric macro."
          }
        }
      },
      {
        "title": "KAIJU.NC: Chronoblade",
        "properties": {
          "kaijuNC.chronoblade.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable KAIJU Chronoblade hover estimates on G1, G2, and G3 moves."
          },
          "kaijuNC.chronoblade.xAxisMode": {
            "type": "string",
            "enum": [
              "diameter",
              "radius"
            ],
            "default": "diameter",
            "description": "How KAIJU Chronoblade interprets X-axis values. Diameter mode uses X for CSS diameter and half-X for physical X travel."
          },
          "kaijuNC.chronoblade.cssSurfaceSpeedUnit": {
            "type": "string",
            "enum": [
              "mPerMin",
              "sfm"
            ],
            "default": "mPerMin",
            "description": "Unit used for G96 constant surface speed calculations."
          },
          "kaijuNC.chronoblade.samples": {
            "type": "integer",
            "default": 96,
            "minimum": 12,
            "maximum": 500,
            "description": "Number of samples used for KAIJU Chronoblade path and CSS/RPM-limit estimates."
          },
          "kaijuNC.chronoblade.compactPanelWidth": {
            "type": "number",
            "default": 0.45,
            "minimum": 0.2,
            "maximum": 0.7,
            "description": "Target width fraction for the KAIJU Chronoblade side editor group when VS Code has a simple two-column layout."
          },
          "kaijuNC.chronoblade.rapidRate": {
            "type": "number",
            "default": 10000,
            "minimum": 0,
            "description": "Default G0 rapid rate used by the KAIJU Chronoblade cycle-time report, in program units per minute."
          },
          "kaijuNC.chronoblade.toolChangeSeconds": {
            "type": "number",
            "default": 4,
            "minimum": 0,
            "description": "Default base tool swap time used by the KAIJU Chronoblade cycle-time report, in seconds."
          },
          "kaijuNC.chronoblade.extraStationSeconds": {
            "type": "number",
            "default": 0.5,
            "minimum": 0,
            "description": "Default extra turret station time added for each station beyond an adjacent tool swap in the KAIJU Chronoblade cycle-time report."
          }
        }
      }
    ],
    "commands": [
      {
        "command": "kaijuNC.formatDocument",
        "title": "KAIJU Reconstructor"
      },
      {
        "command": "kaijuNC.aliasMacros",
        "title": "KAIJU Alias"
      },
      {
        "command": "kaijuNC.orphanKiller",
        "title": "KAIJU Orphan Killer"
      },
      {
        "command": "kaijuNC.chronoblade",
        "title": "KAIJU Chronoblade"
      }
    ],
    "keybindings": [
      {
        "command": "kaijuNC.formatDocument",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus && editorLangId == gcode"
      },
      {
        "command": "kaijuNC.aliasMacros",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus && editorLangId == gcode"
      },
      {
        "command": "kaijuNC.orphanKiller",
        "key": "ctrl+alt+o",
        "mac": "cmd+alt+o",
        "when": "editorTextFocus && editorLangId == gcode"
      },
      {
        "command": "kaijuNC.chronoblade",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus && editorLangId == gcode"
      }
    ],

    "menus": {
      "editor/context": [
        {
          "command": "kaijuNC.formatDocument",
          "when": "editorLangId == gcode",
          "group": "navigation"
        },
        {
          "command": "kaijuNC.aliasMacros",
          "when": "editorLangId == gcode",
          "group": "navigation"
        },
        {
          "command": "kaijuNC.orphanKiller",
          "when": "editorLangId == gcode",
          "group": "navigation"
        },
        {
          "command": "kaijuNC.chronoblade",
          "when": "editorLangId == gcode",
          "group": "navigation"
        }
      ]
    }
  }
}
