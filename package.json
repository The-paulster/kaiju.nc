{
  "name": "kaiju-nc",
  "displayName": "KAIJU.NC",
  "description": "VSCode extension for working with .nc files. Provides syntax highlighting, warnings, automatic formatting, and basic diagnostic tools.",
  "version": "0.3.0",
  "icon": "media/kaiju-nc_128x128icon.png",
  "publisher": "PaulCGilesLawson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-paulster/kaiju.nc.git"
  },
  "bugs": {
    "url": "https://github.com/The-paulster/kaiju.nc/issues"
  },
  "homepage": "https://github.com/The-paulster/kaiju.nc#readme",
  "keywords": [
    "gcode",
    "g-code",
    "nc",
    "cnc",
    "cnc-programming",
    "fanuc",
    "machining",
    "macro",
    "macro-variables",
    "cnc-macro",
    "syntax-highlighting",
    "formatter",
    "g-code-formatter",
    "lathe",
    "turning",
    "mill",
    "milling",
    "mill-turn",
    "tooling",
    "kakou",
    "加工",
    "マシニング"
  ],
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gcode",
        "aliases": ["GCode", "gcode"],
        "extensions": [
          ".nc",
          ".nd",
          ".cnc",
          ".tap",
          ".gcode",
          ".gco",
          ".gc",
          ".ngc",
          ".ncc",
          ".eia",
          ".iso",
          ".min",
          ".mpf",
          ".spf",
          ".dnc",
          ".sub"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gcode",
        "scopeName": "source.gcode",
        "path": "./syntaxes/gcode.tmLanguage.json"
      }
    ],
    


    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "name": "Normal comments",
                "scope": "comment.line.gcode",
                "settings": {
                    "foreground": "#67825e"
                }
            },
            {
                "name": "Title comments",
                "scope": "comment.title.gcode",
                "settings": {
                    "foreground": "#f2ad0c",
                    "fontStyle": "bold"
                }
            },
            {
                "name": "Equals comments",
                "scope": "comment.equals.gcode",
                "settings": {
                    "foreground": "#C4F20C"
                }
            },
            {
                "name": "Meta comments",
                "scope": "comment.meta.gcode",
                "settings": {
                    "foreground": "#95b8bf"
                }
            },
            {
                "name": "Macro variables",
                "scope": "variable.parameter.gcode",
                "settings": {
                    "foreground": "#ffffff"
                }
            },
            {
                "name": "Program number",
                "scope": "entity.name.program.gcode",
                "settings": {
                    "foreground": "#FFD866",
                    "fontStyle": "bold"
                }
            },
            {
                "name": "Block number",
                "scope": "entity.block.number.gcode",
                "settings": {
                    "foreground": "#c4c4c4"
                }
            },
            {
                "name": "Rapid motion G0",
                "scope": "keyword.motion.rapid.gcode",
                "settings": {
                    "foreground": "#ff8800"
                }
            },
            {
                "name": "Cutting motion G1/G2/G3",
                "scope": "keyword.motion.cut.gcode",
                "settings": {
                    "foreground": "#ffd500"
                }
            },
            {
                "name": "Other G-codes",
                "scope": "keyword.control.gcode",
                "settings": {
                    "foreground": "#29c718"
                }
            },
            {
                "name": "M-codes",
                "scope": "keyword.control.mcode.gcode",
                "settings": {
                    "foreground": "#9CDCFE"
                }
            },
            {
                "name": "X axis",
                "scope": "support.axis.x.gcode",
                "settings": {
                    "foreground": "#D65D5D"
                }
            },
            {
                "name": "U axis / X incremental",
                "scope": "support.axis.u.gcode",
                "settings": {
                    "foreground": "#FF8A8A"
                }
            },
            {
                "name": "Y axis",
                "scope": "support.axis.y.gcode",
                "settings": {
                    "foreground": "#6A9955"
                }
            },
            {
                "name": "V axis / Y incremental",
                "scope": "support.axis.v.gcode",
                "settings": {
                    "foreground": "#9CDC7C"
                }
            },
            {
                "name": "Z axis",
                "scope": "support.axis.z.gcode",
                "settings": {
                    "foreground": "#4A90E2"
                }
            },
            {
                "name": "W axis / Z incremental",
                "scope": "support.axis.w.gcode",
                "settings": {
                    "foreground": "#8CC8FF"
                }
            },
            {
                "name": "Radius R",
                "scope": "support.radius.r.gcode",
                "settings": {
                    "foreground": "#D19A66"
                }
            },
            {
                "name": "Feed F",
                "scope": "support.feed.f.gcode",
                "settings": {
                    "foreground": "#ffd84d"
                }
            },
            {
                "name": "L code",
                "scope": "support.code.l.gcode",
                "settings": {
                    "foreground": "#B5CEA8"
                }
            },
            {
                "name": "P code",
                "scope": "support.code.p.gcode",
                "settings": {
                    "foreground": "#D7BA7D"
                }
            },
            {
                "name": "Q code",
                "scope": "support.code.q.gcode",
                "settings": {
                    "foreground": "#CE9178"
                }
            },
            {
                "name": "S code",
                "scope": "support.code.s.gcode",
                "settings": {
                    "foreground": "#ff0037"
                }
            },
            {
                "name": "T code",
                "scope": "support.code.t.gcode",
                "settings": {
                    "foreground": "#88ff00",
                    "fontStyle": "bold"
                }
            },
            {
                "name": "H code",
                "scope": "support.code.h.gcode",
                "settings": {
                    "foreground": "#A6E66A",
                    "fontStyle": "bold"
                }
            },
            {
                "name": "Math symbol operators",
                "scope": "keyword.operator.math.symbol.gcode",
                "settings": {
                    "foreground": "#ABB2BF"
                }
            },
            {
                "name": "Math word operators",
                "scope": "keyword.operator.math.word.gcode",
                "settings": {
                    "foreground": "#eb17e4"
                }
            },
            {
                "name": "Logic Word Operators",
                "scope": "keyword.control.logic.gcode",
                "settings": {
                    "foreground": "#eb17e4"
                }
            },
            {
                "name": "Double comment",
                "scope": "comment.double.gcode",
                "settings": {
                    "foreground": "#94709c"
                }
            },
            {
                "name": "Curly brace comment",
                "scope": "comment.brace.gcode",
                "settings": {
                    "foreground": "#81aec4"
                }
            },
            {
                "name": "A rotary axis",
                "scope": "support.axis.a.gcode",
                "settings": {
                    "foreground": "#8E6BB8"
                }
            },
            {
                "name": "B rotary axis",
                "scope": "support.axis.b.gcode",
                "settings": {
                    "foreground": "#A878D6"
                }
            },
            {
                "name": "C rotary axis",
                "scope": "support.axis.c.gcode",
                "settings": {
                    "foreground": "#C678DD"
                }
            },
            {
                "name": "I arc / X arc component",
                "scope": "support.arc.i.gcode",
                "settings": {
                    "foreground": "#B94F5A"
                }
            },
            {
                "name": "J arc / Y arc component",
                "scope": "support.arc.j.gcode",
                "settings": {
                    "foreground": "#5F8F4E"
                }
            },
            {
                "name": "K arc / Z arc component",
                "scope": "support.arc.k.gcode",
                "settings": {
                    "foreground": "#4B82C2"
                }
            },
            {
                "name": "Main title comment",
                "scope": "comment.maintitle.gcode",
                "settings": {
                    "foreground": "#D0FF00",
                    "fontStyle": "bold"
                }
            }
        ]
      },
      "[gcode]": {
        "editor.colorDecorators": false,
        "editor.defaultColorDecorators": "never"
      },
      "files.associations": {
        "*.nc": "gcode",
        "*.cnc": "gcode",
        "*.tap": "gcode",
        "*.gcode": "gcode",
        "*.gco": "gcode",
        "*.gc": "gcode",
        "*.ngc": "gcode",
        "*.ncc": "gcode",
        "*.eia": "gcode",
        "*.iso": "gcode",
        "*.min": "gcode",
        "*.mpf": "gcode",
        "*.spf": "gcode",
        "*.dnc": "gcode",
        "*.sub": "gcode"
      }
    },
    "configuration": [
      {
        "title": "KAIJU.NC: Syntax",
        "properties": {
          "kaijuNC.syntax.toolDecorations.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Show KAIJU.NC tool-range gutter markers beside G-code programs."
          },
          "kaijuNC.syntax.unresolvedGotos.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Show an error when a GOTO target does not have a matching N label."
          }
        }
      },
      {
        "title": "KAIJU.NC: Code Alerts",
        "properties": {
          "kaijuNC.alerts.nonAscii.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Warn when a G-code file contains non-ASCII characters that some lathe controls may not read reliably."
          },
          "kaijuNC.alerts.duplicateSequenceNumbers.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Show an error when the same N sequence number appears more than once in a G-code file."
          },
          "kaijuNC.alerts.sequenceNumberOrder.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Show an error when N sequence numbers decrease instead of staying in order."
          },
          "kaijuNC.alerts.mixedAliasMode.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Show an error when a G-code file mixes KAIJU Alias names and their original numeric macros."
          },
          "kaijuNC.alerts.undefinedAliases.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Show an error when a named KAIJU Alias macro is used without a matching alias definition before the first G/M block."
          }
        }
      },
      {
        "title": "KAIJU.NC: Reconstructor",
        "properties": {
          "kaijuNC.format.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable KAIJU.NC document formatting for G-code files."
          },
          "kaijuNC.format.decimalPlaces": {
            "type": "integer",
            "default": 3,
            "minimum": 0,
            "maximum": 9,
            "description": "Default number of decimal places used by KAIJU Reconstructor."
          },
          "kaijuNC.format.addMissingDecimal": {
            "type": "boolean",
            "default": true,
            "description": "Add a decimal point to configured address values when one is missing."
          },
          "kaijuNC.format.decimalAddressLetters": {
            "type": "string",
            "default": "XYZUVWABCIJKRF",
            "description": "Address letters whose numeric values should be formatted with decimal places."
          },
          "kaijuNC.format.autoSemicolon": {
            "type": "boolean",
            "default": false,
            "description": "Add semicolons after code and before comments during formatting."
          },
          "kaijuNC.format.normalizeToolCodes": {
            "type": "boolean",
            "default": true,
            "description": "Normalize numeric T codes without inventing offsets, such as T1 to T01 and T606 to T0606."
          },
          "kaijuNC.format.leadingWhitespace": {
            "type": "string",
            "default": "preserveTabs",
            "enum": [
              "preserveTabs",
              "preserve",
              "normalize"
            ],
            "enumDescriptions": [
              "Remove stray leading spaces, preserve leading tabs and full soft-tabs, and auto-indent WHILE/END blocks using the detected indent style.",
              "Preserve all leading spaces and tabs, except when auto-indenting WHILE/END blocks using the detected indent style.",
              "Normalize leading whitespace across the document using WHILE/END block depth and the detected indent style."
            ],
            "description": "Controls how KAIJU Reconstructor handles leading whitespace."
          },
          "kaijuNC.format.softTabSize": {
            "type": "integer",
            "default": 4,
            "minimum": 1,
            "maximum": 16,
            "description": "Number of leading spaces KAIJU Reconstructor treats as one intentional soft-tab indentation unit."
          }
        }
      },
      {
        "title": "KAIJU.NC: Alias",
        "properties": {
          "kaijuNC.alias.caseSensitive": {
            "type": "boolean",
            "default": false,
            "description": "Match KAIJU Alias macro names case-sensitively when toggling aliases. Disabled by default so #PART_OD can still toggle back to #100."
          }
        }
      },
      {
        "title": "KAIJU.NC: Orphan Killer",
        "properties": {
          "kaijuNC.orphanKiller.compactPanelWidth": {
            "type": "number",
            "default": 0.3,
            "minimum": 0.15,
            "maximum": 0.5,
            "description": "Target width fraction for the KAIJU Orphan Killer side editor group when VS Code has a simple two-column layout."
          },
          "kaijuNC.orphanKiller.ignoredMacros": {
            "type": "string",
            "default": "1001-",
            "description": "Comma-separated macro numbers or ranges ignored by KAIJU Orphan Killer, such as 100, 123, 3000-4000, or 1001- for all macros above #1000. Clear this setting to inspect every numeric macro."
          }
        }
      },
      {
        "title": "KAIJU.NC: Decomposition",
        "properties": {
          "kaijuNC.decomposition.comparisonTolerance": {
            "type": "number",
            "default": 1e-7,
            "minimum": 0,
            "description": "Numeric tolerance used by KAIJU Decomposition when evaluating macro comparisons such as EQ, NE, GT, GE, LT, and LE."
          }
        }
      },
      {
        "title": "KAIJU.NC: Display",
        "properties": {
          "kaijuNC.display.minimumDecimalPlaces": {
            "type": "integer",
            "default": 3,
            "minimum": 0,
            "maximum": 9,
            "description": "Minimum decimal places shown in human-facing KAIJU numeric readouts."
          },
          "kaijuNC.display.maximumDecimalPlaces": {
            "type": "integer",
            "default": 3,
            "minimum": 0,
            "maximum": 9,
            "description": "Maximum decimal places shown in human-facing KAIJU numeric readouts. Set this above the minimum to allow extra precision in display text."
          },
          "kaijuNC.display.statusBarModeColors": {
            "type": "boolean",
            "default": true,
            "description": "Color the right-side KAIJU machine-mode and alias-mode status bar indicators."
          }
        }
      },
      {
        "title": "KAIJU.NC: Sense",
        "properties": {
          "kaijuNC.sense.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable KAIJU Sense motion hovers on G0, G1, G2, and G3 moves."
          },
          "kaijuNC.sense.labelReferences.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Show inline reference markers after N labels targeted by GOTO statements."
          },
          "kaijuNC.sense.statusBarVerbose": {
            "type": "boolean",
            "default": true,
            "description": "Show verbose labels in the left-side KAIJU Sense cursor-state status bar, such as G00 (Rapid), instead of only modal codes. This does not affect the right-side machine-mode indicator."
          },
          "kaijuNC.sense.statusBarSyntaxColors": {
            "type": "boolean",
            "default": true,
            "description": "Color the left-side KAIJU Sense cursor-state status bar codes with colors matching KAIJU.NC syntax highlighting. VS Code applies this by splitting the readout into adjacent status bar items."
          },
          "kaijuNC.sense.syntaxColoredHoverValues": {
            "type": "boolean",
            "default": false,
            "description": "Experimental: show KAIJU Sense motion-hover values in G-code code blocks so VS Code can apply syntax coloring. This is taller and currently less readable than the default compact hover; leave it off unless you are testing it."
          },
          "kaijuNC.sense.xAxisMode": {
            "type": "string",
            "enum": [
              "diameter",
              "radius"
            ],
            "default": "diameter",
            "description": "How KAIJU Sense interprets X-axis values. Diameter mode uses X for CSS diameter and half-X for physical X travel."
          },
          "kaijuNC.sense.cssSurfaceSpeedUnit": {
            "type": "string",
            "enum": [
              "mPerMin",
              "sfm"
            ],
            "default": "mPerMin",
            "description": "Unit used by KAIJU Sense for G96 constant surface speed calculations."
          },
          "kaijuNC.sense.samples": {
            "type": "integer",
            "default": 96,
            "minimum": 12,
            "maximum": 500,
            "description": "Number of samples used for KAIJU Sense path and CSS/RPM-limit estimates."
          },
          "kaijuNC.sense.rapidRate": {
            "type": "number",
            "default": 10000,
            "minimum": 0,
            "description": "Default G0 rapid rate used by KAIJU Sense hovers, in program units per minute."
          }
        }
      },
      {
        "title": "KAIJU.NC: Vision",
        "properties": {
          "kaijuNC.vision.plane": {
            "type": "string",
            "enum": [
              "xz",
              "xy",
              "zy"
            ],
            "default": "xz",
            "description": "Default 2D plane used by KAIJU Vision."
          },
          "kaijuNC.vision.xAxisMode": {
            "type": "string",
            "enum": [
              "diameter",
              "radius"
            ],
            "default": "diameter",
            "description": "How KAIJU Vision interprets X-axis values. Diameter mode uses half-X for physical X arc and distance calculations."
          },
          "kaijuNC.vision.g53.x": {
            "type": "number",
            "default": 0,
            "description": "Preview X coordinate used by KAIJU Vision when drawing G53 machine-coordinate moves that contain an X word."
          },
          "kaijuNC.vision.g53.y": {
            "type": "number",
            "default": 0,
            "description": "Preview Y coordinate used by KAIJU Vision when drawing G53 machine-coordinate moves that contain a Y word."
          },
          "kaijuNC.vision.g53.z": {
            "type": "number",
            "default": 0,
            "description": "Preview Z coordinate used by KAIJU Vision when drawing G53 machine-coordinate moves that contain a Z word."
          },
          "kaijuNC.vision.xyOrientation": {
            "type": "string",
            "enum": [
              "xRightYUp",
              "xRightYDown",
              "xLeftYUp",
              "xLeftYDown",
              "yRightXUp",
              "yRightXDown",
              "yLeftXUp",
              "yLeftXDown"
            ],
            "default": "xRightYUp",
            "description": "Controls how KAIJU Vision orients the X-Y plane."
          },
          "kaijuNC.vision.xzOrientation": {
            "type": "string",
            "enum": [
              "zRightXUp",
              "zRightXDown",
              "zLeftXUp",
              "zLeftXDown",
              "xRightZUp",
              "xRightZDown",
              "xLeftZUp",
              "xLeftZDown"
            ],
            "default": "zRightXUp",
            "description": "Controls how KAIJU Vision orients the X-Z plane."
          },
          "kaijuNC.vision.zyOrientation": {
            "type": "string",
            "enum": [
              "zRightYUp",
              "zRightYDown",
              "zLeftYUp",
              "zLeftYDown",
              "yRightZUp",
              "yRightZDown",
              "yLeftZUp",
              "yLeftZDown"
            ],
            "default": "zRightYUp",
            "description": "Controls how KAIJU Vision orients the Z-Y plane."
          },
          "kaijuNC.vision.cssSurfaceSpeedUnit": {
            "type": "string",
            "enum": [
              "mPerMin",
              "sfm"
            ],
            "default": "mPerMin",
            "description": "Unit used by KAIJU Vision for G96 constant surface speed calculations."
          },
          "kaijuNC.vision.samples": {
            "type": "integer",
            "default": 96,
            "minimum": 12,
            "maximum": 500,
            "description": "Number of samples used by KAIJU Vision for arc path drawing."
          },
          "kaijuNC.vision.compactPanelWidth": {
            "type": "number",
            "default": 0.55,
            "minimum": 0.25,
            "maximum": 0.8,
            "description": "Target width fraction for the KAIJU Vision side editor group when VS Code has a simple two-column layout."
          },
          "kaijuNC.vision.zoomStep": {
            "type": "number",
            "default": 1.75,
            "minimum": 1.01,
            "maximum": 5,
            "description": "Multiplier used by KAIJU Vision zoom buttons. The default is three times larger than the previous button step."
          },
          "kaijuNC.vision.wheelZoomStep": {
            "type": "number",
            "default": 1.36,
            "minimum": 1.01,
            "maximum": 5,
            "description": "Multiplier used by KAIJU Vision mouse-wheel zoom. The default is three times larger than the previous wheel step."
          },
          "kaijuNC.vision.lineThickness": {
            "type": "number",
            "default": 1,
            "minimum": 0.1,
            "maximum": 5,
            "description": "Scale factor for KAIJU Vision path line thickness."
          },
          "kaijuNC.vision.arrowSize": {
            "type": "number",
            "default": 1,
            "minimum": 0.1,
            "maximum": 5,
            "description": "Scale factor for KAIJU Vision path direction arrow size."
          },
          "kaijuNC.vision.endpointSize": {
            "type": "number",
            "default": 3,
            "minimum": 1,
            "maximum": 24,
            "description": "Endpoint marker radius in KAIJU Vision, in screen pixels."
          },
          "kaijuNC.vision.startPointSize": {
            "type": "number",
            "default": 4,
            "minimum": 1,
            "maximum": 24,
            "description": "Start-point marker radius in KAIJU Vision, in screen pixels."
          },
          "kaijuNC.vision.labelFontSize": {
            "type": "number",
            "default": 11,
            "minimum": 5,
            "maximum": 32,
            "description": "Endpoint and start label font size in KAIJU Vision, in screen pixels."
          },
          "kaijuNC.vision.labelOffset": {
            "type": "number",
            "default": 10,
            "minimum": 0,
            "maximum": 80,
            "description": "Distance between KAIJU Vision point markers and their labels, in screen pixels."
          },
          "kaijuNC.vision.endpointLabelAvoidance": {
            "type": "boolean",
            "default": false,
            "description": "Experimental: move KAIJU Vision endpoint labels away from endpoint dots and other labels when possible, drawing a small connector line when a label is displaced. Off by default because dense programs can make the current layout pass slow or awkward."
          },
          "kaijuNC.vision.compassSize": {
            "type": "number",
            "default": 78,
            "minimum": 24,
            "maximum": 220,
            "description": "KAIJU Vision compass size in screen pixels."
          },
          "kaijuNC.vision.compassOffsetX": {
            "type": "number",
            "default": 14,
            "minimum": 0,
            "maximum": 240,
            "description": "KAIJU Vision compass horizontal offset from the left edge, in screen pixels."
          },
          "kaijuNC.vision.compassOffsetY": {
            "type": "number",
            "default": 14,
            "minimum": 0,
            "maximum": 240,
            "description": "KAIJU Vision compass vertical offset from the top edge, in screen pixels."
          },
          "kaijuNC.vision.rapidRate": {
            "type": "number",
            "default": 10000,
            "minimum": 0,
            "description": "Default G0 rapid rate used by KAIJU Vision timing context, in program units per minute."
          }
        }
      },
      {
        "title": "KAIJU.NC: Chronoblade",
        "properties": {
          "kaijuNC.chronoblade.machineMode": {
            "type": "string",
            "enum": [
              "mill",
              "latheRadius",
              "latheDiameter"
            ],
            "default": "latheDiameter",
            "description": "Machine mode used by KAIJU Chronoblade, Sense, and Vision. Mill uses radius X and feed-per-minute defaults; lathe modes use feed-per-rev defaults."
          },
          "kaijuNC.chronoblade.xAxisMode": {
            "type": "string",
            "enum": [
              "diameter",
              "radius"
            ],
            "default": "diameter",
            "description": "How KAIJU Chronoblade interprets X-axis values. Diameter mode uses X for CSS diameter and half-X for physical X travel."
          },
          "kaijuNC.chronoblade.cssSurfaceSpeedUnit": {
            "type": "string",
            "enum": [
              "mPerMin",
              "sfm"
            ],
            "default": "mPerMin",
            "description": "Unit used for G96 constant surface speed calculations."
          },
          "kaijuNC.chronoblade.samples": {
            "type": "integer",
            "default": 96,
            "minimum": 12,
            "maximum": 500,
            "description": "Number of samples used for KAIJU Chronoblade path and CSS/RPM-limit estimates."
          },
          "kaijuNC.chronoblade.compactPanelWidth": {
            "type": "number",
            "default": 0.45,
            "minimum": 0.2,
            "maximum": 0.7,
            "description": "Target width fraction for the KAIJU Chronoblade side editor group when VS Code has a simple two-column layout."
          },
          "kaijuNC.chronoblade.rapidRate": {
            "type": "number",
            "default": 10000,
            "minimum": 0,
            "description": "Default G0 rapid rate used by the KAIJU Chronoblade cycle-time report, in program units per minute."
          },
          "kaijuNC.chronoblade.toolChangeSeconds": {
            "type": "number",
            "default": 4,
            "minimum": 0,
            "description": "Default base tool swap time used by the KAIJU Chronoblade cycle-time report, in seconds."
          },
          "kaijuNC.chronoblade.extraStationSeconds": {
            "type": "number",
            "default": 0.5,
            "minimum": 0,
            "description": "Default extra turret station time added for each station beyond an adjacent tool swap in the KAIJU Chronoblade cycle-time report."
          }
        }
