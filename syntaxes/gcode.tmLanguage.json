	"repository": {
		"metacomments": {
			"patterns": [
				{
					"name": "comment.meta.gcode",
					"match": "\\(/[^\\)]*\\)"
				}
			]
		},
		"titlecomments": {
			"patterns": [
				{
					"name": "comment.title.gcode",
					"match": "\\(-[^\\)]*\\)"
				}
			]
		},
		"comments": {
			"name": "comment.line.gcode",
			"begin": "\\(",
			"end": "\\)",
			"patterns": [
				{
					"name": "comment.double.gcode",
					"begin": "\\[",
					"end": "\\]"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"name": "variable.parameter.gcode",
					"match": "#(?:\\d+|[A-Za-z_][A-Za-z0-9_]*)"
				}
			]
		},
		"mcodes": {
			"patterns": [
				{
					"name": "keyword.control.mcode.gcode",
					"match": "\\b[Mm]\\d+\\b"
				}
			]
		},
		"blocknumbers": {
			"patterns": [
				{
					"name": "entity.block.number.gcode",
					"match": "\\b[Nn]\\d+\\b"
				}
			]
		},
		"rapidgcodes": {
			"patterns": [
				{
					"name": "keyword.motion.rapid.gcode",
					"match": "\\b[Gg]0+\\b"
				}
			]
		},
		"cuttinggcodes": {
			"patterns": [
				{
					"name": "keyword.motion.cut.gcode",
					"match": "\\b[Gg]0*[123]\\b"
				}
			]
		},
		"gcodes": {
			"patterns": [
				{
					"name": "keyword.control.gcode",
					"match": "\\b[Gg](?!0+\\b|0*[123]\\b)\\d+\\b"
				}
			]
		},
		"mathoperators": {
			"patterns": [
				{
					"name": "keyword.operator.math.symbol.gcode",
					"match": "[+\\-*/=]"
				},
				{
					"name": "keyword.operator.math.word.gcode",
					"match": "\\b(?:EQ|NE|GT|GE|LT|LE|AND|OR|XOR|MOD|SIN|COS|TAN|ATAN|SQRT|ABS|ROUND|FIX|FUP|LN|EXP)\\b"
				}
			]
		},
		"mathwordoperators": {
			"patterns": [
				{
					"name": "keyword.operator.math.word.gcode",
					"match": "\\b(?:EQ|NE|GT|GE|LT|LE|AND|OR|XOR|MOD|SIN|COS|TAN|ATAN|SQRT|ABS|ROUND|FIX|FUP|LN|EXP)\\b"
				}
			]
		},
		"xwords": {
			"patterns": [
				{
					"name": "support.axis.x.gcode",
					"match": "\\b[Xx](?:[-+]?(?:\\d+(?:\\.\\d*)?|\\.\\d+)|[-+]?#(?:\\d+|[A-Za-z_][A-Za-z0-9_]*)|(?=\\[))"
				}
			]
		},
		"ywords": {
			"patterns": [
				{
					"name": "support.axis.y.gcode",
					"match": "\\b[Yy](?:[-+]?(?:\\d+(?:\\.\\d*)?|\\.\\d+)|[-+]?#(?:\\d+|[A-Za-z_][A-Za-z0-9_]*)|(?=\\[))"
				}
			]
		},
		"zwords": {
			"patterns": [
				{
					"name": "support.axis.z.gcode",
					"match": "\\b[Zz](?:[-+]?(?:\\d+(?:\\.\\d*)?|\\.\\d+)|[-+]?#(?:\\d+|[A-Za-z_][A-Za-z0-9_]*)|(?=\\[))"
				}
			]
		},
		"uwords": {
			"patterns": [
				{
					"name": "support.axis.u.gcode",
					"match": "\\b[Uu](?:[-+]?(?:\\d+(?:\\.\\d*)?|\\.\\d+)|[-+]?#(?:\\d+|[A-Za-z_][A-Za-z0-9_]*)|(?=\\[))"
				}
			]
		},
		"vwords": {
			"patterns": [
				{
					"name": "support.axis.v.gcode",
					"match": "\\b[Vv](?:[-+]?(?:\\d+(?:\\.\\d*)?|\\.\\d+)|[-+]?#(?:\\d+|[A-Za-z_][A-Za-z0-9_]*)|(?=\\[))"
				}
			]
		},
		"wwords": {
			"patterns": [
				{
					"name": "support.axis.w.gcode",
