				}
			]
		},
		"logickeywords": {
			"patterns": [
				{
					"name": "keyword.control.logic.gcode",
					"match": "\\b(?:IF|THEN|WHILE|DO|END|ELSE|GOTO)\\b"
				}
			]
		},
		"xbracketvalues": {
			"patterns": [
				{
					"name": "support.axis.x.gcode",
					"begin": "\\b[Xx]\\[",
					"end": "\\]",
					"patterns": [
						{
							"include": "#mathwordoperators"
						},
						{
							"include": "#bracketnest"
						}
					]
				}
			]
		},
		"ybracketvalues": {
